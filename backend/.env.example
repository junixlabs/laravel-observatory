# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# PostgreSQL Database Configuration
DATABASE_URL=postgresql+asyncpg://sidmonitor:password@localhost:5432/sidmonitor

# ClickHouse Configuration
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=sid_monitoring
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Basic Auth (legacy)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Ingest API Keys (comma-separated) - Used by Laravel SDK to send logs
INGEST_API_KEYS=your-api-key-1,your-api-key-2
